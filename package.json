    "keybindings": [
      {
        "command": "skycms.rename",
        "key": "f2",
        "when": "view == skycmsExplorer && (viewItem == fileNode || viewItem == folderNode)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "skycms.switchFieldLanguage",
          "when": "resourceScheme == skycms",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "skycms.showRootMenu",
          "when": "view == skycmsExplorer && viewItem == rootNode",
          "group": "inline"
        },
        {
          "command": "skycms.refresh",
          "when": "view == skycmsExplorer && viewItem == rootNode",
          "group": "navigation@1"
        },
        {
          "command": "skycms.openPublicSite",
          "when": "view == skycmsExplorer && viewItem == rootNode",
          "group": "skycms@1"
        },
