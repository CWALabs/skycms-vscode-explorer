{
  "name": "skycms-explorer",
  "displayName": "SkyCMS Explorer",
  "description": "Developer-first VS Code Explorer for SkyCMS websites. Manage your sites, articles, layouts, and files directly from VS Code. Visit https://sky-cms.com to learn more.",
  "version": "0.9.39",
  "publisher": "cwalabs",
  "homepage": "https://sky-cms.com",
  "author": {
    "name": "Custom Web Arts",
    "url": "https://github.com/CWALabs"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/CWALabs/skycms-vscode-explorer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onUri"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true});require('fs').rmSync('out',{recursive:true,force:true})\"",
    "build": "npm run compile",
    "build:web": "npm run clean && tsc -p ./ --noEmit && node esbuild.config.mjs --production --web",
    "build:production": "npm run clean && tsc -p ./ --noEmit && node esbuild.config.mjs --production",
    "compile": "npm run clean && tsc -p ./ && node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "package": "npm run build:production && vsce package",
    "test": "jest --config jest.config.js --passWithNoTests",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:watch": "jest --config jest.config.js --watch",
    "lint": "echo \"No lint configured\""
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.11",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  },
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "skycmsExplorer",
          "name": "SkyCMS",
          "initiallyCollapsed": true
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "skycmsExplorer",
        "contents": "No SkyCMS site is configured yet.\n[Add Site](command:skycms.addSite)\nYou can add as many sites as you need and switch between them at any time.\n\n**Tip:** Drag this panel just below the File Explorer for the best experience — SkyCMS Explorer is a virtual website view that pairs naturally with the real file view above it.\n\n[Documentation](https://docs.sky-cms.com/)",
        "when": "skycms.hasSite == false"
      }
    ],
    "chatInstructions": [
      {
        "path": "./prompts/skycms.instructions.md"
      }
    ],
    "chatParticipants": [
      {
        "id": "skycms-explorer.skycms",
        "name": "skycms",
        "fullName": "SkyCMS",
        "description": "Ask about SkyCMS concepts, docs, and extension workflows",
        "isSticky": true,
        "commands": [
          {
            "name": "docs",
            "description": "Point me to the SkyCMS docs for this topic"
          },
          {
            "name": "explain",
            "description": "Explain a SkyCMS concept in practical terms"
          },
          {
            "name": "layouts",
            "description": "Show the best docs for SkyCMS layouts"
          },
          {
            "name": "templates",
            "description": "Show the best docs for SkyCMS templates"
          },
          {
            "name": "articles",
            "description": "Show the best docs for articles and content flow"
          }
        ],
        "disambiguation": [
          {
            "category": "skycms-docs",
            "description": "Questions about SkyCMS concepts, CMS structure, layouts, templates, articles, blog posts, or where SkyCMS documentation can be found.",
            "examples": [
              "How do SkyCMS layouts work?",
              "Where are the SkyCMS docs for templates?",
              "Explain the difference between articles and blog posts in SkyCMS"
            ]
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "skycms.signIn",
        "title": "Sign In"
      },
      {
        "command": "skycms.signOut",
        "title": "Sign Out"
      },
      {
        "command": "skycms.addSite",
        "title": "Add Web Site"
      },
      {
        "command": "skycms.switchSite",
        "title": "Switch Web Site"
      },
      {
        "command": "skycms.removeSite",
